local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

local MODE = "attack"
local SUBMODE = "smart"
local TARGET_NAME = "sitcough"

local RADIUS = 20
local FARLANDS = false

local currentTarget
local originalCFrame

local swarmAngle = 0

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getRoot(model)
	return model and model:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(model)
	return model and model:FindFirstChildOfClass("Humanoid")
end

local function getTargetModel()
	for _, v in ipairs(workspace:GetDescendants()) do
		if v:IsA("Model") and v.Name == TARGET_NAME and getRoot(v) and getHumanoid(v) then
			return v
		end
	end
end

local function hasSword(model)
	for _, v in ipairs(model:GetChildren()) do
		if v:IsA("Tool") and v:FindFirstChild("SwordScript") then
			return true
		end
	end
	return false
end

local function lunge()
	for i = 1, 2 do
		VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
		task.wait(0.02)
		VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
		task.wait(0.02)
	end
end

local function getFlatPrediction(root)
	local vel = root.AssemblyLinearVelocity

	local horizontal = Vector3.new(vel.X, 0, vel.Z)
	local speed = horizontal.Magnitude

	local t = math.clamp(speed / 60, 0.08, 0.25)

	return horizontal * t
end

RunService.RenderStepped:Connect(function(dt)
	local character = getCharacter()
	local myRoot = getRoot(character)

	if not myRoot then return end

	local target = getTargetModel()
	if not target then return end

	local targetRoot = getRoot(target)
	local targetHum = getHumanoid(target)

	if not targetRoot or not targetHum then return end

	if MODE == "attack" and not hasSword(target) then
		return
	end

	if currentTarget then
		local distFromCenter = (targetRoot.Position - myRoot.Position).Magnitude

		if targetHum.Health <= 0 or distFromCenter > RADIUS then
			currentTarget = nil
			return
		end

		local vel = targetRoot.AssemblyLinearVelocity
		local speed = vel.Magnitude

		local predicted = targetRoot.Position + getFlatPrediction(targetRoot)

		-- jump control (prevents fling)
		if math.abs(vel.Y) > 6 then
			predicted = Vector3.new(predicted.X, targetRoot.Position.Y, predicted.Z)
		end

		local tpPos

		if SUBMODE == "swarm" then
			swarmAngle += dt * 6

			local offset = Vector3.new(
				math.cos(swarmAngle) * (RADIUS - 2),
				-7,
				math.sin(swarmAngle) * (RADIUS - 2)
			)

			tpPos = predicted + offset
		else
			tpPos = predicted + Vector3.new(0, -7, 0)
		end

		local goalCFrame = CFrame.lookAt(tpPos, predicted) * CFrame.Angles(0,0,math.rad(90))

		myRoot.CFrame = myRoot.CFrame:Lerp(goalCFrame, 0.35)

		lunge()

		return
	end

	local dist = (targetRoot.Position - myRoot.Position).Magnitude

	if dist <= RADIUS then
		currentTarget = target
		originalCFrame = myRoot.CFrame
	end
end)
