local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

local MODE = "attack"
local TARGET_NAME = "sitcough"
local RADIUS = 20
local FARLANDS = false

local currentTarget
local originalCFrame

local gui = Instance.new("ScreenGui")
gui.Name = "SitcoughUI"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 200)
frame.Position = UDim2.new(0, 20, 0.5, -100)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.BorderSizePixel = 0
frame.Parent = gui

local radiusBox = Instance.new("TextBox")
radiusBox.Size = UDim2.new(0, 200, 0, 30)
radiusBox.Position = UDim2.new(0, 10, 0, 10)
radiusBox.PlaceholderText = "Radius"
radiusBox.Text = tostring(RADIUS)
radiusBox.TextColor3 = Color3.new(1,1,1)
radiusBox.BackgroundColor3 = Color3.fromRGB(40,40,40)
radiusBox.Parent = frame

local playerBox = Instance.new("TextBox")
playerBox.Size = UDim2.new(0, 200, 0, 30)
playerBox.Position = UDim2.new(0, 10, 0, 50)
playerBox.PlaceholderText = "Player Name"
playerBox.Text = TARGET_NAME
playerBox.TextColor3 = Color3.new(1,1,1)
playerBox.BackgroundColor3 = Color3.fromRGB(40,40,40)
playerBox.Parent = frame

local modeButton = Instance.new("TextButton")
modeButton.Size = UDim2.new(0, 200, 0, 30)
modeButton.Position = UDim2.new(0, 10, 0, 90)
modeButton.Text = "Mode: attack"
modeButton.TextColor3 = Color3.new(1,1,1)
modeButton.BackgroundColor3 = Color3.fromRGB(60,60,60)
modeButton.Parent = frame

local farlandsButton = Instance.new("TextButton")
farlandsButton.Size = UDim2.new(0, 200, 0, 30)
farlandsButton.Position = UDim2.new(0, 10, 0, 130)
farlandsButton.Text = "Farlands: OFF"
farlandsButton.TextColor3 = Color3.new(1,1,1)
farlandsButton.BackgroundColor3 = Color3.fromRGB(60,60,60)
farlandsButton.Parent = frame

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(0, 200, 0, 20)
statusLabel.Position = UDim2.new(0, 10, 0, 170)
statusLabel.BackgroundTransparency = 1
statusLabel.TextColor3 = Color3.new(1,0,0)
statusLabel.Text = "ewfjknjkhfwejhwefkhj"
statusLabel.Parent = frame

modeButton.MouseButton1Click:Connect(function()
	if MODE == "attack" then
		MODE = "bodyguard"
	else
		MODE = "attack"
	end

	modeButton.Text = "Mode: "..MODE
end)

farlandsButton.MouseButton1Click:Connect(function()
	FARLANDS = not FARLANDS

	if FARLANDS then
		farlandsButton.Text = "Farlands: ON"
	else
		farlandsButton.Text = "Farlands: OFF"
	end
end)

radiusBox.FocusLost:Connect(function()
	local num = tonumber(radiusBox.Text)

	if num then
		RADIUS = num
	end
end)

playerBox.FocusLost:Connect(function()
	TARGET_NAME = playerBox.Text
end)

local radiusPart = Instance.new("Part")
radiusPart.Anchored = true
radiusPart.CanCollide = false
radiusPart.CastShadow = false
radiusPart.Transparency = 0.7
radiusPart.Material = Enum.Material.Plastic
radiusPart.Color = Color3.fromRGB(255,0,0)
radiusPart.Parent = workspace

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getRoot(model)
	return model and model:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(model)
	return model and model:FindFirstChildOfClass("Humanoid")
end

local function getTargetModel()
	for _, v in ipairs(workspace:GetDescendants()) do
		if v:IsA("Model")
			and v.Name == TARGET_NAME
			and getRoot(v)
			and getHumanoid(v) then
			return v
		end
	end
end

local function hasSword(model)
	for _, v in ipairs(model:GetChildren()) do
		if v:IsA("Tool") and v:FindFirstChild("SwordScript") then
			return true
		end
	end

	return false
end

local function spamLunge()
	for i = 1, 6 do
		VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
		task.wait(0.01)
		VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
		task.wait(0.01)
	end
end

RunService.RenderStepped:Connect(function()
	local character = getCharacter()
	local myRoot = getRoot(character)

	if not myRoot then
		return
	end

	if FARLANDS and not currentTarget then
		myRoot.CFrame = CFrame.new(0,1000000,0)
		myRoot.AssemblyLinearVelocity = Vector3.zero
		myRoot.AssemblyAngularVelocity = Vector3.zero
	end

	local defended = getTargetModel()

	if not defended then
		statusLabel.Text = "Target Missing"
		radiusPart.Transparency = 1
		return
	end

	local defendedRoot = getRoot(defended)

	local showRadius = true

	if MODE == "attack" and not hasSword(defended) then
		showRadius = false
	end

	if showRadius then
		radiusPart.Transparency = 0.7
		radiusPart.Size = Vector3.new(RADIUS * 2, RADIUS * 2, RADIUS * 2)
		radiusPart.CFrame = defendedRoot.CFrame
	else
		radiusPart.Transparency = 1
	end

	if MODE == "attack" and not hasSword(defended) then
		statusLabel.Text = "Waiting For Sword"
		return
	end

	if currentTarget then
		local targetRoot = getRoot(currentTarget)
		local targetHum = getHumanoid(currentTarget)

		if not targetRoot
			or not targetHum
			or targetHum.Health <= 0
			or (defendedRoot.Position - targetRoot.Position).Magnitude > RADIUS then

			myRoot.AssemblyLinearVelocity = Vector3.zero
			myRoot.AssemblyAngularVelocity = Vector3.zero

			task.wait(0.05)

			if originalCFrame then
				myRoot.CFrame = originalCFrame
			end

			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = true
				end
			end

			currentTarget = nil
			originalCFrame = nil

			statusLabel.Text = "jkewjkhwekhjewf"

			return
		end

		statusLabel.Text = "Attacking "..currentTarget.Name

		for _, part in ipairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = false
			end
		end

		myRoot.AssemblyLinearVelocity = Vector3.zero
		myRoot.AssemblyAngularVelocity = Vector3.zero

		local tpPos = targetRoot.Position + Vector3.new(0,-7.7,0)

		myRoot.CFrame =
			CFrame.lookAt(tpPos, targetRoot.Position) *
			CFrame.Angles(0,0,math.rad(90)) *
			CFrame.new(-1.5,0,0)

		spamLunge()

		return
	end

	for _, target in ipairs(workspace:GetDescendants()) do
		if target:IsA("Model")
			and target ~= defended
			and target ~= character
			and getRoot(target)
			and getHumanoid(target) then

			local targetRoot = getRoot(target)
			local targetHum = getHumanoid(target)

			if targetHum.Health > 0 then
				local distance = (defendedRoot.Position - targetRoot.Position).Magnitude

				if distance <= RADIUS then
					originalCFrame = myRoot.CFrame
					currentTarget = target
					statusLabel.Text = "Target Locked"
					break
				end
			end
		end
	end
end)
