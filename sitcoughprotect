local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

local MODE = "attack"
local TARGET_NAME = "sitcough"
local RADIUS = 20
local FARLANDS = false
local SPIN = false

local PREDICTION = 0.52
local UNDERGROUND_OFFSET = -7

local spinAngle = 0

local currentTarget
local originalCFrame

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getRoot(model)
	return model and model:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(model)
	return model and model:FindFirstChildOfClass("Humanoid")
end

local function getTargetModel()
	for _, v in ipairs(workspace:GetDescendants()) do
		if v:IsA("Model") and v.Name == TARGET_NAME and getRoot(v) and getHumanoid(v) then
			return v
		end
	end
end

RunService.RenderStepped:Connect(function()
	local character = getCharacter()
	local myRoot = getRoot(character)
	if not myRoot then return end

	local target = getTargetModel()
	if not target then return end

	local targetRoot = getRoot(target)
	if not targetRoot then return end

	if FARLANDS and not currentTarget then
		myRoot.CFrame = CFrame.new(targetRoot.Position + Vector3.new(0, 2000, 0))
		myRoot.AssemblyLinearVelocity = Vector3.zero
		myRoot.AssemblyAngularVelocity = Vector3.zero
	end

	if currentTarget then
		local root = getRoot(currentTarget)
		local hum = getHumanoid(currentTarget)

		if not root or not hum or hum.Health <= 0 then
			currentTarget = nil
			return
		end

		spinAngle += SPIN and 0.9 or 0

		local vel = root.AssemblyLinearVelocity

		local predicted = Vector3.new(
			root.Position.X + vel.X * PREDICTION,
			root.Position.Y,
			root.Position.Z + vel.Z * PREDICTION
		)

		local basePos = predicted + Vector3.new(0, UNDERGROUND_OFFSET, 0)

		if SPIN then
			local radius = 3
			basePos = basePos + Vector3.new(
				math.cos(spinAngle) * radius,
				0,
				math.sin(spinAngle) * radius
			)
		end

		myRoot.CFrame = CFrame.new(basePos)
		return
	end

	for _, v in ipairs(workspace:GetDescendants()) do
		if v:IsA("Model") and v ~= character and v.Name == TARGET_NAME then
			local root = getRoot(v)
			local hum = getHumanoid(v)

			if root and hum and hum.Health > 0 then
				local dist = (targetRoot.Position - root.Position).Magnitude
				if dist <= RADIUS then
					currentTarget = v
					originalCFrame = myRoot.CFrame
					break
				end
			end
		end
	end
end)
