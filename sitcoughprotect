local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer

local MODE = "attack"
local SUBMODE = "smart"
local TARGET_NAME = "sitcough"

local RADIUS = 20
local currentTarget = nil
local swarmAngle = 0

--// SAFE character getter
local function getCharacter()
	local char = player.Character or player.CharacterAdded:Wait()
	local root = char:WaitForChild("HumanoidRootPart", 5)
	local hum = char:WaitForChild("Humanoid", 5)
	return char, root, hum
end

local function getRoot(model)
	return model and model:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(model)
	return model and model:FindFirstChildOfClass("Humanoid")
end

local function getTarget()
	for _, v in ipairs(workspace:GetChildren()) do
		if v:IsA("Model") and v.Name == TARGET_NAME then
			if getRoot(v) and getHumanoid(v) then
				return v
			end
		end
	end
end

local function lunge()
	for i = 1, 2 do
		VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
		task.wait(0.02)
		VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
		task.wait(0.02)
	end
end

--// UI test (if you don’t see this, script is NOT running)
task.spawn(function()
	print("AI script loaded successfully")
end)

RunService.RenderStepped:Connect(function(dt)
	local char, myRoot = getCharacter()
	if not myRoot then return end

	local target = getTarget()
	if not target then return end

	local targetRoot = getRoot(target)
	local targetHum = getHumanoid(target)
	if not targetRoot or not targetHum then return end

	-- acquire target
	if not currentTarget then
		if (targetRoot.Position - myRoot.Position).Magnitude <= RADIUS then
			currentTarget = target
		else
			return
		end
	end

	-- validate target still alive
	if targetHum.Health <= 0 then
		currentTarget = nil
		return
	end

	local vel = targetRoot.AssemblyLinearVelocity
	local flatVel = Vector3.new(vel.X, 0, vel.Z)

	local predictionTime = math.clamp(flatVel.Magnitude / 60, 0.08, 0.22)
	local predicted = targetRoot.Position + flatVel * predictionTime

	-- stop jump fling
	if math.abs(vel.Y) > 6 then
		predicted = Vector3.new(predicted.X, targetRoot.Position.Y, predicted.Z)
	end

	local tpPos = predicted + Vector3.new(0, -7, 0)

	local goal = CFrame.lookAt(tpPos, predicted) * CFrame.Angles(0,0,math.rad(90))

	myRoot.CFrame = myRoot.CFrame:Lerp(goal, 0.35)

	lunge()
end)
