	-- ============================================================
	-- CODE EDITOR — LINE NUMBERS
	-- ============================================================
	local function HMEQ_fake_script()
		local script = Instance.new("LocalScript", ScrollBox)
		local FontSize = CodeBox.TextSize
		local TopCount

		local function resize(iter)
			ScrollBox.CanvasSize = UDim2.new(0, ScrollBox.CanvasSize.X.Offset, 0, iter * FontSize)
			ScrollBox.CanvasPosition = Vector2.new(ScrollBox.CanvasPosition.X, iter * FontSize)
		end

		CodeBox:GetPropertyChangedSignal("Text"):Connect(function()
			local str = CodeBox.Text
			local offset = 36
			local textX = CodeBox.TextBounds.X + offset
			ScrollBox.CanvasSize = UDim2.new(0, textX, 0, ScrollBox.CanvasSize.Y.Offset)
			local _, count = str:gsub("\n", "\n")
			local newCount = count + 1
			if not LineNumbers.Text:find(newCount) then
				TopCount = newCount
				for i = 1, TopCount do
					if not LineNumbers.Text:find(i) then
						LineNumbers.Text = tostring(LineNumbers.Text..i.."\n")
					end
				end
				resize(TopCount)
			else
				if TopCount ~= newCount and TopCount ~= nil then
					LineNumbers.Text = ""
					TopCount = newCount
					for i = 1, TopCount do LineNumbers.Text = tostring(LineNumbers.Text..i.."\n") end
					resize(TopCount)
				end
			end
		end)
	end
	coroutine.wrap(HMEQ_fake_script)()

