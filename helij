	-- Tween helpers
	local function tween(obj, props, t, style, dir)
		t = t or 0.35
		style = style or Enum.EasingStyle.Quint
		dir = dir or Enum.EasingDirection.Out
		return TweenService:Create(obj, TweenInfo.new(t, style, dir), props)
	end

	local function tweenPos(obj, pos, t)
		obj:TweenPosition(pos, Enum.EasingDirection.Out, Enum.EasingStyle.Quint, t or 0.55, true)
	end

	-- Corner radius helper
	local function corner(parent, r)
		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(0, r or 12)
		c.Parent = parent
		return c
	end

	-- Stroke helper
	local function stroke(parent, color, thickness, trans)
		local s = Instance.new("UIStroke")
		s.Color = color or C.BORDER
		s.Thickness = thickness or 1
		s.Transparency = trans or 0.5
		s.Parent = parent
		return s
	end

	-- Gradient helper
	local function gradient(parent, c0, c1, rot)
		local g = Instance.new("UIGradient")
		g.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, c0),
			ColorSequenceKeypoint.new(1, c1),
		}
		if rot then g.Rotation = rot end
		g.Parent = parent
		return g
	end

